---
const projects = [
  {
    name: 'qe',
    url: 'https://jeff.lookingforteam.com/qe',
    github: 'https://github.com/obscuren/qe',
    description: 'Fast, lightweight terminal editor with modal editing and built-in git.',
    lang: 'C',
  },
  {
    name: 'astra',
    url: 'https://jeff.lookingforteam.com/astra',
    github: 'https://github.com/obscuren/crawler',
    description: 'Sci-fi rogue dungeon crawler.',
    lang: 'C++',
  },
  {
    name: 'tinyvm',
    url: 'https://github.com/obscuren/tinyvm',
    github: 'https://github.com/obscuren/tinyvm',
    description: 'Minimalistic virtual machine.',
    lang: 'Go',
  },
];
---

<section id="side-projects" class="section">
  <div class="container">
    <div class="section__label">Side Projects</div>
    <h2 class="section__heading">Things I tinker with.</h2>

    <div class="side-projects__list stagger">
      {projects.map(project => (
        <div class="side-project">
          <a href={project.url} target="_blank" rel="noopener" class="side-project__link">
            <div class="side-project__header">
              <span class="side-project__name">{project.name}</span>
              <span class="side-project__lang">{project.lang}</span>
            </div>
            <p class="side-project__description">{project.description}</p>
          </a>
          <a href={project.github} target="_blank" rel="noopener" class="side-project__gh" aria-label={`${project.name} on GitHub`}>
            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"/></svg>
          </a>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .side-projects__list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-xl);
  }

  .side-project {
    position: relative;
    border: 1px solid var(--color-border-light);
    transition: all var(--transition-fast);
    flex: 1 1 280px;
    max-width: 400px;
  }

  .side-project:hover {
    border-color: var(--color-border);
    background: var(--color-bg-alt);
  }

  .side-project__link {
    display: block;
    padding: var(--space-md) var(--space-lg);
    padding-right: calc(var(--space-lg) + 24px);
  }

  .side-project__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-sm);
  }

  .side-project__name {
    font-family: var(--font-mono);
    font-size: var(--text-base);
    font-weight: 500;
  }

  .side-project__lang {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
  }

  .side-project__gh {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
    display: flex;
    align-items: center;
    z-index: 1;
  }

  .side-project__gh:hover {
    color: var(--color-accent);
  }

  .side-project__description {
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    line-height: 1.5;
  }
</style>
