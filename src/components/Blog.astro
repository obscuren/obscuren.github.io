---
import { getCollection } from 'astro:content';

const base = import.meta.env.BASE_URL;
const allPosts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const posts = allPosts.slice(0, 6);
const hasMore = allPosts.length > 6;
---

<section id="blog" class="section">
  <div class="container">
    <div class="section__label">Blog</div>
    <h2 class="section__heading">Dev logs & thoughts.</h2>

    <div class="blog__grid stagger">
      {posts.map(post => (
        <article class="blog-card">
          <time class="blog-card__date">{post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' })}</time>
          <h3 class="blog-card__title">
            <a href={`${base}blog/${post.id}`}>{post.data.title}</a>
          </h3>
          <p class="blog-card__excerpt">{post.data.excerpt}</p>
          <span class="blog-card__tag">{post.data.tag}</span>
        </article>
      ))}
    </div>

    {hasMore && (
      <a href={`${base}blog`} class="blog__view-all">View all posts &rarr;</a>
    )}
  </div>
</section>

<style>
  .blog__view-all {
    display: inline-block;
    margin-top: var(--space-xl);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: var(--border-style);
    padding: var(--space-sm) var(--space-lg);
    transition: all var(--transition-fast);
  }

  .blog__view-all:hover {
    background: var(--color-text);
    color: var(--color-text-inverse);
  }
</style>
